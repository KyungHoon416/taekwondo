rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 배너 이미지: 어드민만 쓰기, 누구나 읽기
    match /banners/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 900 * 1024  // 900KB 제한
        && request.resource.contentType.matches('image/.*');
    }

    // 커뮤니티 첨부 이미지: 로그인 사용자 쓰기, 누구나 읽기
    match /community/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 1100 * 1024  // 1.1MB 제한 (여유분)
        && request.resource.contentType.matches('image/.*');
    }

    // 기타 경로는 기본 차단
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
