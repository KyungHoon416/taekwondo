{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "seed.js",
      ".git/**",
      ".firebase/**",
      "firebase-debug.log",
      ".agents/**",
      ".codex/**",
      ".claude/**",
      "pg/**",
      "**/.*",
      "**/node_modules/**",
      ".npm-cache/**"
    ],
    "rewrites": [
      {
        "source": "/pg/**",
        "run": {
          "serviceId": "taekwoncareer-pg",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/admin.html",
        "destination": "/admin.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  }
}
